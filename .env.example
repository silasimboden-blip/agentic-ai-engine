# Google Authentication Configuration
# Default path on Windows : C:\Users\<your-username>\AppData\Roaming\gcloud\application_default_credentials.json
# Default path on Mac : /home/<your-username>/.config/gcloud/application_default_credentials.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/application_default_credentials.json

# Google Cloud Platform Configuration
GOOGLE_CLOUD_PROJECT=your-project-id

# https://docs.cloud.google.com/vertex-ai/docs/general/locations#europe
GOOGLE_CLOUD_LOCATION=your-location

# Google Cloud Storage Configuration
GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name

# Use Vertex AI as the backend for google-genai, so no API is required
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Google Cloud Logging Configuration
GOOGLE_CLOUD_LOGGING_PROJECT=your-project-id

# Application Configuration
APP_NAME=agentic-ai-system
APP_ENV=development
APP_DEBUG=true

# Default agent to use when a connection starts
DEFAULT_AGENT_ID=greeting_agent

# Default LLM model for agents
DEFAULT_LLM_MODEL=gemini-2.5-flash

# Session backend: "VERTEX" for VertexAiSessionService, "IN_MEMORY" for InMemorySessionService.
# Defaults to "IN_MEMORY" locally, "VERTEX" on Cloud Run.
SESSION_BACKEND=IN_MEMORY

# Structured Logging (structlog)
# LOG_ENV is auto-detected: "console" locally, "gcp" on Cloud Run
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# A2A (Agent-to-Agent) — external critic agent
# ---------------------------------------------------------------------------
# URL of the critic agent's A2A Agent Card (used by the summarizer to connect)
CRITIC_A2A_URL=http://localhost:8001/.well-known/agent.json
# Host and port for the critic A2A server
CRITIC_A2A_HOST=localhost
CRITIC_A2A_PORT=8001

# Database Configuration (if needed)
DATABASE_URL=sqlite:///./app.db

